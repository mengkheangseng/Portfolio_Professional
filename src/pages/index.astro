---
import Layout from '../layouts/Layout.astro';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '../components/ui/card';
import { Button } from '../components/ui/button';
import { Badge } from '../components/ui/badge';
---

<Layout title="Mengkheang Seng | Software Engineer">
  <main class="max-w-4xl mx-auto p-6 md:p-12 space-y-10">
    
    <!-- HERO SECTION -->
    <section class="space-y-4 pt-8">
      <div class="space-y-2">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
          Hi, I'm <span class="text-blue-600 dark:text-blue-400">Mengkheang Seng</span>
        </h1>
        <p class=" py-5 text-xl md:text-2xl font-semibold text-muted-foreground">
          Software Engineer & IT Management Intern
        </p>
      </div>
      <p class="text-base md:text-lg text-muted-foreground leading-relaxed max-w-2xl">
        <div class="space-y-6"> <p>Computer Science and IT Management student passionate about applying analytical skills and technical frameworks through real-world projects and collaborative problem-solving.</p> <p>I love exploring advanced technologies, leveraging modern AI workflows, and experimenting with new tools to build forward-thinking solutions.</p> </div>
      
      <!-- STYLED CLICKABLE MAIN LINKS -->
		<div class="flex flex-wrap gap-4 pt-4">
			<!-- GITHUB BUTTON -->
			<Button asChild variant="ghost" class="cursor-pointer p-0 h-auto hover:bg-transparent">
				<a href="https://github.com/mengkheangseng" target="_blank" rel="noopener noreferrer" class="group text-indigo-500 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-200  transition-colors duration-200 font-medium flex items-center gap-1">
				<span class= "group-hover:underline">GitHub Profile</span>
				<span class="text-xs text-indigo-300">↗</span>
				</a>
			</Button> 

			<!-- LINKEDIN BUTTON -->
			<Button asChild variant="ghost" class="cursor-pointer p-0 h-auto hover:bg-transparent">
				<a href="https://linkedin.com/in/mengkheangseng-b541b7305" target="_blank" rel="noopener noreferrer" class="group text-indigo-500 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-200  transition-colors duration-200 font-medium flex items-center gap-1">
				<span class="group-hover:underline">LinkedIn Profile</span>
				<span class="text-xs text-indigo-300">↗</span>
				</a>
			</Button>

			<!-- EMAIL BUTTON -->
			<Button asChild variant="ghost" class="cursor-pointer p-0 h-auto hover:bg-transparent">
				<a href="mailto:official.mengkheangseng@gmail.com" class="group text-indigo-500 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-200  transition-colors duration-200 font-medium flex items-center gap-1">
				<span class="group-hover:underline">official.mengkheangseng@gmail.com</span>
				<span class="text-xs text-indigo-300">↗</span>
				</a>
			</Button>
			</div>
    </section>

    <!-- EDUCATION SECTION -->
    <section class="space-y-5">
      <h2 class="text-2xl font-bold tracking-tight border-b pb-2">Education</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <Card>
          <CardHeader class="pb-2">
            <CardTitle class="text-lg">American University of Phnom Penh</CardTitle>
            <CardDescription>B.S. in Information Technology Management (ITM)</CardDescription>
          </CardHeader>
          <CardContent class="text-sm text-muted-foreground">
            Expected Graduation: 2028 <br />
            <strong>GPA: 3.69/4.00</strong>
          </CardContent>
        </Card>
        <Card>
          <CardHeader class="pb-2">
            <CardTitle class="text-lg">Fort Hays State University (USA)</CardTitle>
            <CardDescription>B.S. in Computer Science</CardDescription>
          </CardHeader>
          <CardContent class="text-sm text-muted-foreground">
            Dual Degree Program with AUPP <br />
            Consistent Academic Excellence
          </CardContent>
        </Card>
      </div>
    </section>

    <!-- TECHNICAL SKILLS -->
    <section class="space-y-5 space-t-10">
      <h2 class="text-2xl font-bold tracking-tight border-b pb-2">Technical Skills</h2>
      <div class="space-y-3">
        <div>
          <span class="text-sm font-semibold block mb-1">Programming:</span>
          <div class="flex flex-wrap gap-1.5">
            <Badge variant="secondary">Python</Badge>
            <Badge variant="secondary">Java</Badge>
            <Badge variant="secondary">C++</Badge>
            <Badge variant="secondary">JavaScript</Badge>
          </div>
        </div>
        <div>
          <span class="text-sm font-semibold block mb-1">Web & Backend:</span>
          <div class="flex flex-wrap gap-1.5">
            <Badge variant="secondary">Vue.js</Badge>
            <Badge variant="secondary">Node.js</Badge>
            <Badge variant="secondary">Express.js</Badge>
            <Badge variant="secondary">Tailwind CSS</Badge>
            <Badge variant="secondary">MongoDB</Badge>
          </div>
        </div>
        <div>
          <span class="text-sm font-semibold block mb-1">Tools & Platforms:</span>
          <div class="flex flex-wrap gap-1.5">
            <Badge variant="secondary">Git</Badge>
            <Badge variant="secondary">GitHub</Badge>
            <Badge variant="secondary">Docker</Badge>
            <Badge variant="secondary">AWS</Badge>
            <Badge variant="secondary">Virtual Machines</Badge>
          </div>
        </div>
      </div>
    </section>

    <!-- SOFT SKILLS -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold tracking-tight border-b pb-2">Soft Skills</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <div class="p-3 border rounded-lg bg-card text-center shadow-sm flex items-center justify-center">
          <span class="text-sm font-medium">collaborative Problem-Solving</span>
        </div>
        <div class="p-3 border rounded-lg bg-card text-center shadow-sm flex items-center justify-center">
          <span class="text-sm font-medium">Analytical Thinking & Grit</span>
        </div>
        <div class="p-3 border rounded-lg bg-card text-center shadow-sm flex items-center justify-center">
          <span class="text-sm font-medium">Self-Learning & Curiosity</span>
        </div>
        <div class="p-3 border rounded-lg bg-card text-center shadow-sm flex items-center justify-center">
          <span class="text-sm font-medium">Adaptability</span>
        </div>
        <div class="p-3 border rounded-lg bg-card text-center shadow-sm flex items-center justify-center col-span-2 md:col-span-1">
          <span class="text-sm font-medium">Time Management</span>
        </div>
      </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold tracking-tight border-b pb-2">Featured Projects</h2>
      <div class="space-y-6">
        
        <!-- Library System -->
        <Card>
          <CardHeader>
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <CardTitle class="text-xl">Library Management System</CardTitle>
                <CardDescription>Backend Developer (Team Project)</CardDescription>
                
                <!-- CLICKABLE PROJECT LINK -->
                <div class="mt-2">
                  <a href="https://github.com/mengkheangseng/Library-system" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline underline-offset-4 inline-flex items-center gap-1">
                    github.com/mengkheangseng/Library-system →
                  </a>
                </div>
              </div>
              <div class="flex gap-1">
                <Badge>Node.js</Badge>
                <Badge>Express.js</Badge>
                <Badge>MongoDB</Badge>
              </div>
            </div>
          </CardHeader>
          <CardContent class="space-y-2 text-sm text-muted-foreground">
            <ul class="list-disc pl-5 space-y-1">
              <li>Developed robust backend functionality for an automated library records management system[cite: 1].</li>
              <li>Implemented secure user registration, authentication, and comprehensive database integration[cite: 1].</li>
              <li>Contributed to application core logic and established seamless git workflow for team collaboration[cite: 1].</li>
            </ul>
          </CardContent>
        </Card>

        <!-- Shop System -->
        <Card>
          <CardHeader>
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <CardTitle class="text-xl">Shop Management System</CardTitle>
                <CardDescription>Application Developer (Individual Project)</CardDescription>
                
                <!-- CLICKABLE PROJECT LINK -->
                <div class="mt-2">
                  <a href="https://github.com/mengkheangseng/Mini-Grocery-System" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline underline-offset-4 inline-flex items-center gap-1">
                    github.com/mengkheangseng/Mini-Grocery-System →
                  </a>
                </div>
              </div>
              <div class="flex gap-1">
                <Badge>C++</Badge>
              </div>
            </div>
          </CardHeader>
          <CardContent class="space-y-2 text-sm text-muted-foreground">
            <ul class="list-disc pl-5 space-y-1">
              <li>Developed a clean console-based grocery management and inventory control application[cite: 1].</li>
              <li>Implemented custom sorting and searching algorithms for efficient checkout, pricing, and discounts[cite: 1].</li>
              <li>Built quantity evaluation metrics and dynamic real-time total calculation logic[cite: 1].</li>
            </ul>
          </CardContent>
        </Card>

        <!-- Weather App -->
        <Card>
          <CardHeader>
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <CardTitle class="text-xl">Weather Forecast Application</CardTitle>
                <CardDescription>Personal Exploration</CardDescription>
                
                <!-- CLICKABLE PROJECT LINK -->
                <div class="mt-2">
                  <a href="https://github.com/mengkheangseng/weather-forecast" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline underline-offset-4 inline-flex items-center gap-1">
                    github.com/mengkheangseng/weather-forecast →
                  </a>
                </div>
              </div>
              <div class="flex gap-1">
                <Badge>Python</Badge>
                <Badge>Java</Badge>
              </div>
            </div>
          </CardHeader>
          <CardContent class="space-y-2 text-sm text-muted-foreground">
            <ul class="list-disc pl-5 space-y-1">
              <li>Explored RESTful API integration and data parsing architectures to build a real-time weather query application[cite: 1].</li>
            </ul>
          </CardContent>
        </Card>

      </div>
    </section>

    <!-- ACHIEVEMENTS & SCHOLARSHIPS -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold tracking-tight border-b pb-2">Scholarships & Achievements</h2>
      <Card>
        <CardContent class="pt-6 text-sm text-muted-foreground">
          <ul class="list-disc pl-5 space-y-2">
            <li><strong>AMT Full Scholarship Recipient</strong> – American University of Phnom Penh[cite: 1]</li>
            <li><strong>Cambodian National Baccalaureate Examination</strong> – Grade A[cite: 1]</li>
            <li><strong>Casio Mathematics Competition</strong> – Grade 12 Winner[cite: 1]</li>
            <li><strong>Casio Mathematics Competition</strong> – Grade 11 3rd Place Winner[cite: 1]</li>
          </ul>
        </CardContent>
      </Card>
    </section>

  </main>
</Layout>